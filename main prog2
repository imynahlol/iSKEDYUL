// [FUNCTION TEMPLATE] swap values for bubble sort
template <typename T>
    void swapValues(T* a, T* b) {
    T temp = *a;
    *a = *b;
    *b = temp;
}

// [BUBBLE SORT WITH POINTERS] sort users array by ID in ascending order for binary search
void bubbleSortUsers(User* arr, int size) {
    for (int i = 0; i < size - 1; i++) {
        for (int j = 0; j < size - i - 1; j++) {
            if (arr[j].id > arr[j + 1].id) {
                swapValues(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// [SELECTION SORT] sort reservations by date in ascending order for better organization and display
void reservationByDate(Reservation* arr, int size) {
    for (int i = 0; i < size - 1; i++) {
        int minIndex = i;
        
        for (int j = i + 1; j < size; j++) {
            if (arr[j].date < arr[minIndex].date) {
                minIndex = j;
            }
        }
        if (minIndex != i) {
            swapValues(&arr[i], &arr[minIndex]);
        }
    }
}

// [FUNCTION RECURSION & BINARY SEARCH] searches for user ID in sorted users array, returns index if found, -1 if not found
int recursiveBinarySearch(User* arr, int low, int high, string targetID) {
    if (high >= low) {
        int mid = low + (high - low) / 2;

        // target found
        if (arr[mid].id == targetID)
            return mid;

        // if target is lower, look at the left half
        if (arr[mid].id > targetID) {
            return recursiveBinarySearch(arr, low, mid - 1, targetID);
        }
        // if target is higher, look at the right half
        return recursiveBinarySearch(arr, mid + 1, high, targetID);
    }
    return -1; //return if ID doesnt exist
}

// [INSERTION SORT] insert new user in sorted order by ID to maintain sorted array for binary search
void insertUserSorted(User* arr, int& count, const User& newUser) {
    int i = count - 1;
    // move elements to the right to make room for the new sorted ID
    while (i >= 0 && arr[i].id > newUser.id) {
        arr[i + 1] = arr[i];
        i--;
    }

    arr[i + 1] = newUser;
    count++;
}

