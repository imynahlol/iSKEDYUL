//[FSTREAM, SEQUENTIAL ACCESS FILE]
//load function - every open ng system; data is not empty
void loadData() {
    ifstream userFile("iSKEDusers.txt"); //for reading file
    ifstream reservationFile("iSKEDreservations.txt");

    //load users
    if (userFile.is_open()) {
        userCount = 0;
        
        while(getline(userFile, users[userCount].id, ';') &&
            getline(userFile, users[userCount].name, ';') &&
            getline(userFile, users[userCount].type, ';') &&
            getline(userFile, users[userCount].program)){
            userCount++;

            if(userCount >= maximumUser)
                break;
        }

        userFile.close(); //when done
        if (userCount > 0){
            bubbleSortUsers(users, userCount);
        }
    }

    //load reservations
    if (reservationFile.is_open()) {
        reservationCount = 0;
        
        while(getline(reservationFile, reservations[reservationCount].building, ';') &&
            getline(reservationFile, reservations[reservationCount].room, ';') &&
            getline(reservationFile, reservations[reservationCount].date, ';') &&
            getline(reservationFile, reservations[reservationCount].time, ';') &&
            getline(reservationFile, reservations[reservationCount].userID, ';') &&
            getline(reservationFile, reservations[reservationCount].userName, ';') &&
            getline(reservationFile, reservations[reservationCount].program, ';') &&
            getline(reservationFile, reservations[reservationCount].status)){
        reservationCount++;
        // only count if all data were read and status is not empty
            if (reservationCount >= maximumReservation)
                break;
        }
        reservationFile.close();
    }
}

//for data to save, temporary to permanent data
void saveData() {
    ofstream userFile("iSKEDusers.txt"); //for writing file
    ofstream reservationFile("iSKEDreservations.txt");

    //save users
    for (int u = 0; u < userCount; u++) {
        userFile << users[u].id << ';'
                 << users[u].name << ';'
                 << users[u].type << ';'
                 << users[u].program << '\n';
    }
    userFile.close();

    //save reservations
    for (int r = 0; r < reservationCount; r++) {
        reservationFile << reservations[r].building << ';'
                        << reservations[r].room << ';'
                        << reservations[r].date << ';'
                        << reservations[r].time << ';'
                        << reservations[r].userID << ';'
                        << reservations[r].userName << ';'
                        << reservations[r].program << ';'
                        << reservations[r].status << '\n';
    }
    reservationFile.close();
}

bool validateID(string id, string type) {
    if (type == "Faculty") { // valid faculty ID: 5 digits
        if (id.length() != 5) {
            maroontext();
            cout << "[X] Invalid Format! Enter 5 Digits only.\n\n";
            resettext();
            return false;
        }

        for (int i = 0; i < 5; i++) { // must use digit only
            if (!isdigit(id[i])) {
                maroontext();
                cout << "[X] Faculty ID must contain only digit.\n\n";
                resettext();
                return false;
            }
        }
        return true;
    } 
    else if (type == "Student") { // Valid student ID Format: 20XX-XXXXX-LQ-0
        if (id.length() != 15) {
            maroontext();
            cout << "[X] Invalid Format!\n\n";
            goldtext();
            cout << "[!] Expected Format: 20XX-XXXXX-LQ-0";
            resettext();
            return false;
        }
        // checking of student ID (DASHES)
        if (id[4] != '-' || id[10] != '-' || id[13] != '-') {
            maroontext();
            cout << "[X] Invalid Format! Incorrect Dash Position.\n\n";
            resettext();
            return false;
        }
        //Part 1: must start with "20"
        if (id[0] != '2' || id[1] != '0') {
            maroontext();
            cout << "[X] ID must start with '20'.\n\n";
            resettext();
            return false;
        }

        //Part 2: check positions 2-3 are digits/year ('25' for 2025)
        for (int i = 2; i <= 3; i++) {
            if (!isdigit(id[i])) {
                maroontext();
                cout << "[X] Year must be in digit.\n\n";
                resettext();
                return false;
            }
        }

        //Part 3: must be 5 digit Student ID no. (pos 5-9)
        for (int i = 5; i <= 9; i++) {
            if (!isdigit(id[i])) {
                maroontext();
                cout << "[X] ID must have 5 Digit Student Number.\n\n";
                resettext();
                return false;
            }
        }

        //Part 4: Must be LQ (pos 11-12)
        if (id[11] != 'L' || id[12] != 'Q') {
            maroontext();
            cout << "[X] Invalid Format!\n"
                 << "    The third part must use 'LQ'.\n\n";
            resettext();
            return false;
        }

        //Part 5: Must end with '0', pos 14
        if (id[14] != '0') {
            maroontext();
            cout << "[X] Invalid Format!\n"
                 << "    Last part must end with '0'.\n\n";
            resettext();
            return false;
        }
        return true;
     }
     return false;
}

